@model Material
@{
    ViewData["Title"] = "Редактировать материал";
}

<div class="row justify-content-center">
<div class="col-md-6">
<div class="card shadow-sm">
    <div class="card-header bg-warning text-dark">
        <h5 class="mb-0"><i class="bi bi-pencil me-2"></i>Редактировать: @Model.Name</h5>
    </div>
    <div class="card-body">
        <form asp-action="Edit" asp-route-id="@Model.Id" method="post">
            @Html.AntiForgeryToken()
            <input asp-for="Id" type="hidden" />
            <div class="mb-3">
                <label asp-for="Name" class="form-label fw-semibold"></label>
                <input asp-for="Name" class="form-control" />
                <span asp-validation-for="Name" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Quantity" class="form-label fw-semibold"></label>
                <input asp-for="Quantity" class="form-control" type="number" step="0.01" min="0" />
            </div>
            <div class="mb-3">
                <label asp-for="UnitOfMeasure" class="form-label fw-semibold"></label>
                <select asp-for="UnitOfMeasure" class="form-select">
                    <option value="кг">кг</option>
                    <option value="шт">шт</option>
                    <option value="литр">литр</option>
                    <option value="м">м</option>
                    <option value="м²">м²</option>
                    <option value="упак">упак</option>
                </select>
            </div>
            <div class="mb-4">
                <label asp-for="MinimalStock" class="form-label fw-semibold"></label>
                <input asp-for="MinimalStock" class="form-control" type="number" step="0.01" min="0" />
            </div>
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-warning flex-fill"><i class="bi bi-save me-1"></i>Обновить</button>
                <a href="/Materials" class="btn btn-outline-secondary">Отмена</a>
            </div>
        </form>
    </div>
</div>
</div>
</div>
