@model Product
@{
    ViewData["Title"] = "Редактировать продукт";
    var materials = ViewBag.Materials as IEnumerable<Material> ?? Enumerable.Empty<Material>();
}

<div class="row justify-content-center">
<div class="col-lg-8">
<div class="card shadow-sm">
    <div class="card-header bg-warning text-dark">
        <h5 class="mb-0"><i class="bi bi-pencil me-2"></i>Редактировать: @Model.Name</h5>
    </div>
    <div class="card-body">
        <form asp-action="Edit" asp-route-id="@Model.Id" method="post">
            @Html.AntiForgeryToken()
            <input asp-for="Id" type="hidden" />
            <div class="row g-3">
                <div class="col-md-6">
                    <label asp-for="Name" class="form-label fw-semibold"></label>
                    <input asp-for="Name" class="form-control" />
                    <span asp-validation-for="Name" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="Category" class="form-label fw-semibold"></label>
                    <input asp-for="Category" class="form-control" />
                </div>
                <div class="col-md-6">
                    <label asp-for="ProductionTimePerUnit" class="form-label fw-semibold"></label>
                    <div class="input-group">
                        <input asp-for="ProductionTimePerUnit" class="form-control" type="number" min="1" />
                        <span class="input-group-text">мин</span>
                    </div>
                </div>
                <div class="col-md-6">
                    <label asp-for="MinimalStock" class="form-label fw-semibold"></label>
                    <input asp-for="MinimalStock" class="form-control" type="number" min="0" />
                </div>
                <div class="col-12">
                    <label asp-for="Description" class="form-label fw-semibold"></label>
                    <textarea asp-for="Description" class="form-control" rows="2"></textarea>
                </div>
                <div class="col-12">
                    <label asp-for="Specifications" class="form-label fw-semibold"></label>
                    <textarea asp-for="Specifications" class="form-control" rows="2"></textarea>
                </div>
            </div>

            <hr class="my-4" />
            <h6 class="fw-bold mb-3"><i class="bi bi-boxes me-1"></i>Необходимые материалы</h6>
            <div id="materialsContainer">
            @foreach (var pm in Model.ProductMaterials)
            {
                <div class="row g-2 mb-2 material-row">
                    <div class="col-md-6">
                        <select name="materialIds" class="form-select">
                            <option value="0">— Выберите материал —</option>
                            @foreach (var m in materials)
                            {
                                @if (pm.MaterialId == m.Id)
                                {
                                    <option value="@m.Id" selected>@m.Name (@m.UnitOfMeasure)</option>
                                }
                                else
                                {
                                    <option value="@m.Id">@m.Name (@m.UnitOfMeasure)</option>
                                }
                            }
                        </select>
                    </div>
                    <div class="col-md-4">
                        <input type="number" name="quantities" class="form-control" step="0.01" min="0" value="@pm.QuantityNeeded" />
                    </div>
                    <div class="col-md-2">
                        <button type="button" class="btn btn-outline-danger w-100" onclick="removeRow(this)"><i class="bi bi-dash"></i></button>
                    </div>
                </div>
            }
            </div>
            <button type="button" class="btn btn-outline-secondary btn-sm mt-1" onclick="addMaterialRow()">
                <i class="bi bi-plus me-1"></i>Добавить материал
            </button>

            <div class="d-flex gap-2 mt-4">
                <button type="submit" class="btn btn-warning flex-fill"><i class="bi bi-save me-1"></i>Обновить</button>
                <a href="/Products" class="btn btn-outline-secondary">Отмена</a>
            </div>
        </form>
    </div>
</div>
</div>
</div>

@section Scripts {
<script>
function addMaterialRow() {
    const container = document.getElementById('materialsContainer');
    const row = document.createElement('div');
    row.className = 'row g-2 mb-2 material-row';
    row.innerHTML = `
        <div class="col-md-6">
            <select name="materialIds" class="form-select">
                <option value="0">— Выберите материал —</option>
                @foreach (var m in materials) {
                    <text><option value="@m.Id">@m.Name (@m.UnitOfMeasure)</option></text>
                }
            </select>
        </div>
        <div class="col-md-4">
            <input type="number" name="quantities" class="form-control" step="0.01" min="0" placeholder="Кол-во" />
        </div>
        <div class="col-md-2">
            <button type="button" class="btn btn-outline-danger w-100" onclick="removeRow(this)"><i class="bi bi-dash"></i></button>
        </div>`;
    container.appendChild(row);
}
function removeRow(btn) { btn.closest('.material-row').remove(); }
</script>
}
