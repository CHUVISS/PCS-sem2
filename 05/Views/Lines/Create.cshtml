@model ProductionLine
@{
    ViewData["Title"] = "Новая линия";
}

<div class="row justify-content-center">
<div class="col-md-6">
<div class="card shadow-sm">
    <div class="card-header bg-primary text-white">
        <h5 class="mb-0"><i class="bi bi-plus-circle me-2"></i>Добавить производственную линию</h5>
    </div>
    <div class="card-body">
        <form asp-action="Create" method="post">
            @Html.AntiForgeryToken()
            <div class="mb-3">
                <label asp-for="Name" class="form-label fw-semibold"></label>
                <input asp-for="Name" class="form-control" placeholder="Линия А, Линия Б..." />
                <span asp-validation-for="Name" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Status" class="form-label fw-semibold"></label>
                <select asp-for="Status" class="form-select">
                    <option value="Active">Active (Активна)</option>
                    <option value="Stopped">Stopped (Остановлена)</option>
                </select>
            </div>
            <div class="mb-4">
                <label asp-for="EfficiencyFactor" class="form-label fw-semibold">
                    Коэффициент эффективности: <strong id="effLabel">1.0×</strong>
                </label>
                <input asp-for="EfficiencyFactor" class="form-range" type="range" min="0.5" max="2.0" step="0.1"
                       value="1.0" oninput="document.getElementById('effLabel').textContent = parseFloat(this.value).toFixed(1) + '×'" />
                <div class="form-text">0.5 = вдвое медленнее, 1.0 = норма, 2.0 = вдвое быстрее</div>
            </div>
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary flex-fill"><i class="bi bi-save me-1"></i>Сохранить</button>
                <a href="/Lines" class="btn btn-outline-secondary">Отмена</a>
            </div>
        </form>
    </div>
</div>
</div>
</div>
