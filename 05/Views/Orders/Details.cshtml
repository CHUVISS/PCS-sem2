@model WorkOrder
@{
    ViewData["Title"] = "Заказ #" + Model.Id;
    var statusMap = new Dictionary<string, (string badge, string label)> {
        ["Pending"]    = ("bg-secondary", "Ожидает"),
        ["InProgress"] = ("bg-primary",   "В работе"),
        ["Completed"]  = ("bg-success",   "Завершён"),
        ["Cancelled"]  = ("bg-danger",    "Отменён"),
    };
    var (badge, label) = statusMap.GetValueOrDefault(Model.Status, ("bg-light text-dark", Model.Status));
}

<div class="d-flex justify-content-between mb-4">
    <h2><i class="bi bi-clipboard-check me-2"></i>Заказ #@Model.Id</h2>
    <a href="/Orders" class="btn btn-outline-secondary">← Назад</a>
</div>

<div class="row g-4">
    <div class="col-md-6">
        <div class="card shadow-sm">
            <div class="card-header"><h6 class="mb-0">Информация о заказе</h6></div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-5">Продукт</dt>
                    <dd class="col-sm-7"><strong>@Model.Product?.Name</strong></dd>
                    <dt class="col-sm-5">Количество</dt>
                    <dd class="col-sm-7">@Model.Quantity шт</dd>
                    <dt class="col-sm-5">Линия</dt>
                    <dd class="col-sm-7">@(Model.ProductionLine?.Name ?? "—")</dd>
                    <dt class="col-sm-5">Статус</dt>
                    <dd class="col-sm-7"><span class="badge @badge">@label</span></dd>
                    <dt class="col-sm-5">Прогресс</dt>
                    <dd class="col-sm-7">
                        <div class="progress" style="height:20px">
                            <div class="progress-bar bg-primary" style="width:@Model.ProgressPercent%">@Model.ProgressPercent%</div>
                        </div>
                    </dd>
                    <dt class="col-sm-5">Начало</dt>
                    <dd class="col-sm-7">@Model.StartDate.ToString("dd.MM.yyyy HH:mm")</dd>
                    <dt class="col-sm-5">Плановое завершение</dt>
                    <dd class="col-sm-7 @(Model.EstimatedEndDate < DateTime.Now && Model.Status == "InProgress" ? "text-danger fw-bold" : "")">
                        @Model.EstimatedEndDate.ToString("dd.MM.yyyy HH:mm")
                    </dd>
                </dl>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card shadow-sm">
            <div class="card-header"><h6 class="mb-0"><i class="bi bi-boxes me-1"></i>Требуемые материалы</h6></div>
            <div class="card-body p-0">
                @if (Model.Product?.ProductMaterials?.Any() == true)
                {
                    <table class="table table-sm mb-0">
                        <thead class="table-light">
                            <tr><th>Материал</th><th>На ед.</th><th>Итого</th><th>Ед.</th></tr>
                        </thead>
                        <tbody>
                        @foreach (var pm in Model.Product.ProductMaterials)
                        {
                            <tr>
                                <td>@pm.Material?.Name</td>
                                <td>@pm.QuantityNeeded</td>
                                <td><strong>@(pm.QuantityNeeded * Model.Quantity)</strong></td>
                                <td>@pm.Material?.UnitOfMeasure</td>
                            </tr>
                        }
                        </tbody>
                    </table>
                }
                else
                {
                    <div class="p-3 text-muted">Нет данных о материалах</div>
                }
            </div>
        </div>
    </div>
</div>
