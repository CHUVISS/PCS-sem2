<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:HttpMonitor.ViewModels"
        xmlns:conv="using:HttpMonitor.Converters"
        xmlns:models="using:HttpMonitor.Models"
        x:Class="HttpMonitor.Views.MainWindow"
        x:DataType="vm:MainViewModel"
        Title="HttpMonitor"
        Width="1220" Height="800"
        MinWidth="960" MinHeight="680"
        Background="#0A0C10"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaChromeHints="NoChrome"
        ExtendClientAreaTitleBarHeightHint="-1">

  <Window.Resources>
    <conv:StatusCodeColorConverter x:Key="StatusColor"/>
    <conv:DirectionColorConverter x:Key="DirColor"/>
    <conv:MethodColorConverter x:Key="MethodColor"/>
    <conv:BoolToColorConverter x:Key="BoolColor"/>
    <conv:BoolToStringConverter x:Key="ServerBtnText"
                                TrueValue="■  Stop Server"
                                FalseValue="▶  Start Server"/>
    <conv:BoolToStringConverter x:Key="SendBtnText"
                                TrueValue="Sending…"
                                FalseValue="Send  →"/>
  </Window.Resources>

  <Grid RowDefinitions="48,*">

    <!-- ════ TITLE BAR ════════════════════════════════════════════ -->
    <Border Grid.Row="0"
            Background="#0D1117"
            BorderBrush="#161B27"
            BorderThickness="0 0 0 1">
      <Grid ColumnDefinitions="140,*,140">
        <StackPanel Grid.Column="0"
                    Orientation="Horizontal"
                    VerticalAlignment="Center"
                    Margin="20 0 0 0"
                    Spacing="8">
          <Ellipse Width="12" Height="12" Fill="#FF5F57"/>
          <Ellipse Width="12" Height="12" Fill="#FEBC2E"/>
          <Ellipse Width="12" Height="12" Fill="#28C840"/>
        </StackPanel>
        <StackPanel Grid.Column="1"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Spacing="10">
          <Border Background="#111827" CornerRadius="5" Padding="6 3">
            <TextBlock Text="HTTP" FontSize="9" FontWeight="Bold"
                       Foreground="#3B82F6" LetterSpacing="2.5"/>
          </Border>
          <TextBlock Text="Monitor" FontSize="14" FontWeight="SemiBold"
                     Foreground="#CBD5E1" VerticalAlignment="Center"/>
        </StackPanel>
        <StackPanel Grid.Column="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Margin="0 0 20 0"
                    Spacing="6">
          <Ellipse Width="6" Height="6"
                   Fill="{Binding ServerRunning, Converter={StaticResource BoolColor}}"/>
          <TextBlock Text="{Binding ServerStatusText}"
                     FontSize="11" Foreground="#374151" VerticalAlignment="Center"/>
        </StackPanel>
      </Grid>
    </Border>

    <!-- ════ BODY ══════════════════════════════════════════════════ -->
    <Grid Grid.Row="1" ColumnDefinitions="280,*,310">

      <!-- ── LEFT: SERVER PANEL ──────────────────────────────────── -->
      <Border Grid.Column="0"
              Background="#0D1117"
              BorderBrush="#161B27"
              BorderThickness="0 0 1 0">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
          <StackPanel Margin="18 22 18 22" Spacing="22">

            <StackPanel Spacing="14">
              <TextBlock Text="SERVER" Classes="h2"/>

              <StackPanel Spacing="6">
                <TextBlock Text="PORT" Classes="label"/>
                <TextBox Text="{Binding ServerPort}"
                         IsEnabled="{Binding !ServerRunning}"
                         Watermark="8080" MaxLength="5"/>
              </StackPanel>

              <Grid ColumnDefinitions="*,10,*">
                <StackPanel Grid.Column="0" Spacing="6">
                  <TextBlock Text="UPTIME" Classes="label"/>
                  <Border Background="#111827" CornerRadius="8"
                          Padding="0 9" BorderBrush="#1E2535" BorderThickness="1">
                    <TextBlock Text="{Binding Uptime}"
                               FontFamily="SF Mono, JetBrains Mono, Menlo, monospace"
                               FontSize="12" Foreground="#4B5563"
                               HorizontalAlignment="Center"/>
                  </Border>
                </StackPanel>
                <StackPanel Grid.Column="2" Spacing="6">
                  <TextBlock Text="TOTAL" Classes="label"/>
                  <Border Background="#111827" CornerRadius="8"
                          Padding="0 9" BorderBrush="#1E2535" BorderThickness="1">
                    <TextBlock Text="{Binding TotalRequests}"
                               FontFamily="SF Mono, JetBrains Mono, Menlo, monospace"
                               FontSize="12" Foreground="#4B5563"
                               HorizontalAlignment="Center"/>
                  </Border>
                </StackPanel>
              </Grid>

              <Button Command="{Binding ToggleServerCommand}"
                      Content="{Binding ServerRunning, Converter={StaticResource ServerBtnText}}"
                      Classes="primary"
                      HorizontalAlignment="Stretch"
                      HorizontalContentAlignment="Center"/>
            </StackPanel>

            <Border Height="1" Background="#161B27"/>

            <StackPanel Spacing="14">
              <TextBlock Text="STATISTICS" Classes="h2"/>
              <Grid ColumnDefinitions="*,8,*">
                <Border Grid.Column="0" Background="#111827" CornerRadius="10"
                        Padding="14 12" BorderBrush="#1C2A42" BorderThickness="1">
                  <StackPanel Spacing="3">
                    <TextBlock Text="GET" FontSize="10" FontWeight="Bold"
                               LetterSpacing="1.5" Foreground="#1D4ED8"/>
                    <TextBlock Text="{Binding GetRequests}"
                               FontSize="26" FontWeight="Light"
                               Foreground="#60A5FA" LetterSpacing="-1"/>
                  </StackPanel>
                </Border>
                <Border Grid.Column="2" Background="#111827" CornerRadius="10"
                        Padding="14 12" BorderBrush="#2D1B69" BorderThickness="1">
                  <StackPanel Spacing="3">
                    <TextBlock Text="POST" FontSize="10" FontWeight="Bold"
                               LetterSpacing="1.5" Foreground="#5B21B6"/>
                    <TextBlock Text="{Binding PostRequests}"
                               FontSize="26" FontWeight="Light"
                               Foreground="#A78BFA" LetterSpacing="-1"/>
                  </StackPanel>
                </Border>
              </Grid>
              <Border Background="#111827" CornerRadius="10"
                      Padding="14 12" BorderBrush="#1E2535" BorderThickness="1">
                <StackPanel Spacing="3">
                  <TextBlock Text="AVG RESPONSE TIME" Classes="label"/>
                  <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Bottom">
                    <TextBlock Text="{Binding AvgDuration}"
                               FontSize="24" FontWeight="Light"
                               Foreground="#E2E8F0" LetterSpacing="-1"/>
                    <TextBlock Text="ms" FontSize="12" Foreground="#374151"
                               VerticalAlignment="Bottom" Margin="0 0 0 2"/>
                  </StackPanel>
                </StackPanel>
              </Border>
            </StackPanel>

            <Border Height="1" Background="#161B27"/>

            <StackPanel Spacing="10">
              <TextBlock Text="PRESETS" Classes="h2"/>
              <StackPanel Spacing="5">
                <Button Classes="ghost" HorizontalAlignment="Stretch"
                        Padding="10 8"
                        Command="{Binding SetUrlPresetCommand}"
                        CommandParameter="https://jsonplaceholder.typicode.com/posts/1">
                  <StackPanel Orientation="Horizontal" Spacing="8">
                    <Border Background="#0F2040" CornerRadius="4" Padding="5 2">
                      <TextBlock Text="GET" FontSize="9" FontWeight="Bold"
                                 Foreground="#3B82F6" LetterSpacing="1"/>
                    </Border>
                    <TextBlock Text="JSONPlaceholder" FontSize="12"
                               Foreground="#6B7280" VerticalAlignment="Center"/>
                  </StackPanel>
                </Button>
                <Button Classes="ghost" HorizontalAlignment="Stretch"
                        Padding="10 8"
                        Command="{Binding SetUrlPresetCommand}"
                        CommandParameter="https://httpbin.org/get">
                  <StackPanel Orientation="Horizontal" Spacing="8">
                    <Border Background="#0F2040" CornerRadius="4" Padding="5 2">
                      <TextBlock Text="GET" FontSize="9" FontWeight="Bold"
                                 Foreground="#3B82F6" LetterSpacing="1"/>
                    </Border>
                    <TextBlock Text="HTTPBin" FontSize="12"
                               Foreground="#6B7280" VerticalAlignment="Center"/>
                  </StackPanel>
                </Button>
                <Button Classes="ghost" HorizontalAlignment="Stretch"
                        Padding="10 8"
                        Command="{Binding SetUrlPresetCommand}"
                        CommandParameter="http://localhost:8080/">
                  <StackPanel Orientation="Horizontal" Spacing="8">
                    <Border Background="#200F40" CornerRadius="4" Padding="5 2">
                      <TextBlock Text="POST" FontSize="9" FontWeight="Bold"
                                 Foreground="#8B5CF6" LetterSpacing="1"/>
                    </Border>
                    <TextBlock Text="Local Server" FontSize="12"
                               Foreground="#6B7280" VerticalAlignment="Center"/>
                  </StackPanel>
                </Button>
              </StackPanel>
            </StackPanel>

          </StackPanel>
        </ScrollViewer>
      </Border>

      <!-- ── CENTER: CLIENT + RESPONSE ─────────────────────────── -->
      <Grid Grid.Column="1" RowDefinitions="*,*">

        <!-- HTTP CLIENT card -->
        <Border Grid.Row="0" Background="#0A0C10" Padding="18 18 18 9">
          <Border Classes="card">
            <Grid RowDefinitions="Auto,14,Auto,10,Auto,10,*">
              <Grid Grid.Row="0" ColumnDefinitions="*,Auto">
                <TextBlock Grid.Column="0" Text="HTTP CLIENT" Classes="h2" VerticalAlignment="Center"/>
                <Border Grid.Column="1" Background="#111827" CornerRadius="8" Padding="3">
                  <StackPanel Orientation="Horizontal" Spacing="2">
                    <Button Content="GET" Classes="tab-active"
                            Command="{Binding SetMethodCommand}"
                            CommandParameter="GET"
                            Padding="14 5" FontSize="12" FontWeight="SemiBold"/>
                    <Button Content="POST" Classes="tab"
                            Command="{Binding SetMethodCommand}"
                            CommandParameter="POST"
                            Padding="14 5" FontSize="12" FontWeight="SemiBold"/>
                  </StackPanel>
                </Border>
              </Grid>

              <TextBlock Grid.Row="2" Text="REQUEST URL" Classes="label"/>

              <Grid Grid.Row="4" ColumnDefinitions="*,10,Auto">
                <TextBox Grid.Column="0"
                         Text="{Binding ClientUrl}"
                         Watermark="https://api.example.com/endpoint"
                         Height="40" VerticalContentAlignment="Center"/>
                <Button Grid.Column="2"
                        Content="{Binding IsSending, Converter={StaticResource SendBtnText}}"
                        Classes="primary"
                        IsEnabled="{Binding !IsSending}"
                        Command="{Binding SendRequestCommand}"
                        MinWidth="110" Height="40"/>
              </Grid>

              <TextBlock Grid.Row="5" Text="REQUEST BODY (JSON)" Classes="label" Margin="0 4 0 0"/>

              <TextBox Grid.Row="6"
                       Text="{Binding RequestBody}"
                       AcceptsReturn="True"
                       TextWrapping="Wrap"
                       ScrollViewer.VerticalScrollBarVisibility="Auto"
                       VerticalContentAlignment="Top"
                       Padding="12"/>
            </Grid>
          </Border>
        </Border>

        <!-- RESPONSE card -->
        <Border Grid.Row="1" Background="#0A0C10" Padding="18 9 18 18">
          <Border Classes="card">
            <Grid RowDefinitions="Auto,12,*">

              <Grid Grid.Row="0" ColumnDefinitions="*,Auto,10,Auto,10,Auto">
                <TextBlock Grid.Column="0" Text="RESPONSE"
                           Classes="h2" VerticalAlignment="Center"/>
                <Border Grid.Column="1" CornerRadius="5" Padding="8 3" Background="#111827">
                  <TextBlock Text="{Binding ResponseStatus}"
                             FontFamily="SF Mono, JetBrains Mono, Menlo, monospace"
                             FontSize="12" FontWeight="Bold"
                             Foreground="{Binding ResponseStatus, Converter={StaticResource StatusColor}}"/>
                </Border>
                <TextBlock Grid.Column="3" FontSize="12" Foreground="#374151"
                           VerticalAlignment="Center">
                  <TextBlock.Text>
                    <MultiBinding StringFormat="{}{0:F0}ms">
                      <Binding Path="ResponseDuration"/>
                    </MultiBinding>
                  </TextBlock.Text>
                </TextBlock>
                <StackPanel Grid.Column="5" Orientation="Horizontal" Spacing="6">
                  <Button Content="Save" Classes="ghost" Padding="8 4"
                          FontSize="11" Command="{Binding SaveLogsCommand}"/>
                  <Button Content="Clear" Classes="ghost" Padding="8 4"
                          FontSize="11" Command="{Binding ClearLogsCommand}"/>
                </StackPanel>
              </Grid>

              <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                <TextBox Text="{Binding ResponseText}"
                         IsReadOnly="True"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         FontFamily="SF Mono, JetBrains Mono, Menlo, monospace"
                         FontSize="12.5"
                         Foreground="#64748B"
                         Background="Transparent"
                         BorderThickness="0"
                         Padding="4"/>
              </ScrollViewer>
            </Grid>
          </Border>
        </Border>
      </Grid>

      <!-- ── RIGHT: LOG PANEL ───────────────────────────────────── -->
      <Border Grid.Column="2"
              Background="#0D1117"
              BorderBrush="#161B27"
              BorderThickness="1 0 0 0">
        <Grid RowDefinitions="Auto,1,*">

          <StackPanel Grid.Row="0" Margin="14 16 14 12" Spacing="10">
            <TextBlock Text="REQUEST LOG" Classes="h2"/>
            <WrapPanel>
              <Button Content="All" Classes="tab-active"
                      Command="{Binding SetFilterCommand}"
                      CommandParameter="ALL"
                      Padding="10 5" FontSize="11" Margin="0 0 4 4"/>
              <Button Content="GET" Classes="tab"
                      Command="{Binding SetFilterCommand}"
                      CommandParameter="GET"
                      Padding="10 5" FontSize="11" Margin="0 0 4 4"/>
              <Button Content="POST" Classes="tab"
                      Command="{Binding SetFilterCommand}"
                      CommandParameter="POST"
                      Padding="10 5" FontSize="11" Margin="0 0 4 4"/>
              <Button Content="↓ IN" Classes="tab"
                      Command="{Binding SetFilterCommand}"
                      CommandParameter="IN"
                      Padding="10 5" FontSize="11" Margin="0 0 4 4"/>
              <Button Content="↑ OUT" Classes="tab"
                      Command="{Binding SetFilterCommand}"
                      CommandParameter="OUT"
                      Padding="10 5" FontSize="11" Margin="0 0 4 4"/>
              <Button Content="2xx" Classes="tab"
                      Command="{Binding SetFilterCommand}"
                      CommandParameter="2xx"
                      Padding="10 5" FontSize="11" Margin="0 0 4 4"/>
              <Button Content="4xx+" Classes="tab"
                      Command="{Binding SetFilterCommand}"
                      CommandParameter="4xx+"
                      Padding="10 5" FontSize="11" Margin="0 0 4 4"/>
            </WrapPanel>
          </StackPanel>

          <Border Grid.Row="1" Background="#161B27"/>

          <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding FilteredLogs}" Margin="8 6 8 14">
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="models:RequestLogEntry">
                  <Border Margin="0 1" CornerRadius="7" Padding="10 8">
                    <Border.Styles>
                      <Style Selector="Border:pointerover">
                        <Setter Property="Background" Value="#111827"/>
                      </Style>
                    </Border.Styles>
                    <Grid ColumnDefinitions="Auto,6,Auto,8,*,6,Auto">
                      <!-- Direction -->
                      <Border Grid.Column="0" CornerRadius="4" Padding="5 2"
                              Background="#0F172A" VerticalAlignment="Center">
                        <TextBlock Text="{Binding Direction}"
                                   FontFamily="SF Mono, JetBrains Mono, Menlo, monospace"
                                   FontSize="9" FontWeight="Bold" LetterSpacing="0.5"
                                   Foreground="{Binding Direction, Converter={StaticResource DirColor}}"/>
                      </Border>
                      <!-- Method -->
                      <Border Grid.Column="2" CornerRadius="4" Padding="5 2"
                              Background="#0F172A" VerticalAlignment="Center">
                        <TextBlock Text="{Binding Method}"
                                   FontFamily="SF Mono, JetBrains Mono, Menlo, monospace"
                                   FontSize="9" FontWeight="Bold" LetterSpacing="0.5"
                                   Foreground="{Binding Method, Converter={StaticResource MethodColor}}"/>
                      </Border>
                      <!-- URL + time -->
                      <StackPanel Grid.Column="4" Spacing="1" VerticalAlignment="Center">
                        <TextBlock Text="{Binding Url}"
                                   FontFamily="SF Mono, JetBrains Mono, Menlo, monospace"
                                   FontSize="11" Foreground="#4B5563"
                                   TextTrimming="CharacterEllipsis"/>
                        <TextBlock Text="{Binding FormattedTime}"
                                   FontSize="10" Foreground="#1F2937"/>
                      </StackPanel>
                      <!-- Status -->
                      <TextBlock Grid.Column="6"
                                 Text="{Binding StatusCode}"
                                 FontFamily="SF Mono, JetBrains Mono, Menlo, monospace"
                                 FontSize="11" FontWeight="SemiBold"
                                 VerticalAlignment="Center"
                                 Foreground="{Binding StatusCode, Converter={StaticResource StatusColor}}"/>
                    </Grid>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </ScrollViewer>

        </Grid>
      </Border>

    </Grid>
  </Grid>
</Window>
